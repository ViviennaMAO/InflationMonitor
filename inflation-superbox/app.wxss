page {
  background-color: #050810;
  color: #E5E7EB;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* ═══ Cards ═══ */
.card {
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(10, 14, 26, 0.95));
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.card-title { font-size: 28rpx; color: #9CA3AF; font-weight: 500; }
.card-subtitle { font-size: 22rpx; color: #6B7280; }

/* ═══ Flex helpers ═══ */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.justify-between { justify-content: space-between; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.gap-sm { gap: 12rpx; }
.gap-md { gap: 20rpx; }

/* ═══ Text colors ═══ */
.text-white { color: #E5E7EB; }
.text-muted { color: #9CA3AF; }
.text-dim { color: #6B7280; }
.text-gold { color: #FBBF24; }
.text-green { color: #10B981; }
.text-amber { color: #F59E0B; }
.text-orange { color: #F97316; }
.text-red { color: #EF4444; }
.text-blue { color: #3B82F6; }
.text-sky { color: #0EA5E9; }
.text-violet { color: #8B5CF6; }
.text-rose { color: #F43F5E; }
.text-teal { color: #14B8A6; }
.text-yellow { color: #EAB308; }

/* ═══ Text sizes ═══ */
.text-xs { font-size: 20rpx; }
.text-sm { font-size: 24rpx; }
.text-md { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 40rpx; }
.text-2xl { font-size: 56rpx; }
.font-mono { font-family: 'Menlo', 'Monaco', 'Courier New', monospace; }
.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }

/* ═══ Regime badges (5 levels) ═══ */
.badge {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
}
.badge-reflation    { background: rgba(239, 68, 68, 0.15); color: #EF4444; border: 1rpx solid rgba(239, 68, 68, 0.3); }
.badge-sticky       { background: rgba(249, 115, 22, 0.15); color: #F97316; border: 1rpx solid rgba(249, 115, 22, 0.3); }
.badge-goldilocks   { background: rgba(234, 179, 8, 0.15); color: #EAB308; border: 1rpx solid rgba(234, 179, 8, 0.3); }
.badge-disinflation { background: rgba(16, 185, 129, 0.15); color: #10B981; border: 1rpx solid rgba(16, 185, 129, 0.3); }
.badge-deflation    { background: rgba(59, 130, 246, 0.15); color: #3B82F6; border: 1rpx solid rgba(59, 130, 246, 0.3); }

/* ═══ Direction badges (asset signals) ═══ */
.badge-bullish   { background: rgba(16, 185, 129, 0.2); color: #10B981; border: 1rpx solid rgba(16, 185, 129, 0.4); }
.badge-neu-bull  { background: rgba(16, 185, 129, 0.1); color: #34D399; border: 1rpx solid rgba(16, 185, 129, 0.3); }
.badge-neutral   { background: rgba(100, 116, 139, 0.2); color: #CBD5E1; border: 1rpx solid rgba(100, 116, 139, 0.3); }
.badge-neu-bear  { background: rgba(239, 68, 68, 0.1); color: #F87171; border: 1rpx solid rgba(239, 68, 68, 0.3); }
.badge-bearish   { background: rgba(239, 68, 68, 0.2); color: #EF4444; border: 1rpx solid rgba(239, 68, 68, 0.4); }

/* ═══ Hawk-dove badges ═══ */
.badge-hawk2 { background: rgba(239, 68, 68, 0.2);  color: #EF4444; }
.badge-hawk1 { background: rgba(245, 158, 11, 0.15); color: #F59E0B; }
.badge-dove0 { background: rgba(100, 116, 139, 0.15); color: #94A3B8; }
.badge-dove1 { background: rgba(6, 182, 212, 0.15); color: #06B6D4; }
.badge-dove2 { background: rgba(59, 130, 246, 0.2); color: #3B82F6; }

/* ═══ Progress bar ═══ */
.progress-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 4rpx;
  overflow: hidden;
  width: 100%;
}
.progress-fill {
  height: 100%;
  border-radius: 4rpx;
}

/* ═══ Formula strip ═══ */
.formula-strip {
  color: #FBBF24;
  font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ═══ Section divider ═══ */
.section-divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 16rpx 0 12rpx;
}
.section-divider .line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.08);
}
.section-divider .label {
  font-size: 22rpx;
  color: #6B7280;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

/* ═══ Tab pills (scenario / fomc) ═══ */
.pill-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}
.pill {
  font-size: 22rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: #9CA3AF;
  background: rgba(15, 23, 42, 0.6);
}
.pill-active {
  background: rgba(251, 191, 36, 0.1);
  border-color: rgba(251, 191, 36, 0.4);
  color: #FBBF24;
}

/* ═══ Status dot (pulse) ═══ */
.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  display: inline-block;
  margin-right: 8rpx;
}

/* ═══ Utility ═══ */
.mb-sm { margin-bottom: 12rpx; }
.mb-md { margin-bottom: 20rpx; }
.mt-sm { margin-top: 12rpx; }
.w-full { width: 100%; }
.text-right { text-align: right; }
.text-center { text-align: center; }
