.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding-bottom: env(safe-area-inset-bottom);
  background: #0A0E1A;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  z-index: 999;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.4);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14rpx 0 18rpx;
  position: relative;
  transition: color 0.18s ease, transform 0.18s ease;
  color: #6B7280;
}

.tab-item-active {
  color: #FBBF24;
}

.tab-icon {
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 6rpx;
  /* Subtle lift for the active tab to feel "selected" */
  transition: transform 0.18s ease;
}

.tab-item-active .tab-icon {
  transform: translateY(-2rpx);
}

.tab-label {
  font-size: 24rpx;
  line-height: 1;
  letter-spacing: 2rpx;
  font-weight: 500;
}

.tab-item-active .tab-label {
  font-weight: 700;
}

.tab-dot {
  position: absolute;
  bottom: 6rpx;
  width: 28rpx;
  height: 3rpx;
  border-radius: 2rpx;
  background: #FBBF24;
  box-shadow: 0 0 12rpx rgba(251, 191, 36, 0.5);
}
