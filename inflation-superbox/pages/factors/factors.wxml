<view class="container">

  <view wx:if="{{loading}}" class="text-center text-muted" style="padding:100rpx 0;">Loading...</view>
  <view wx:elif="{{error}}" class="text-center text-red" style="padding:100rpx 0;">{{error}}</view>

  <block wx:else>
    <view class="section-divider">
      <view class="line"></view>
      <text class="label">P · E · D · F · N</text>
      <view class="line"></view>
    </view>

    <view wx:for="{{components}}" wx:key="key" class="card">
      <!-- Component header -->
      <view class="flex justify-between items-start mb-sm">
        <view class="flex-col">
          <view class="flex items-center gap-sm">
            <text class="text-xl font-bold font-mono" style="color:{{item.color}};">{{item.key}}</text>
            <text class="text-sm text-white">{{item.labelZh}}</text>
          </view>
          <text class="text-xs text-dim" style="margin-top:2rpx;">{{item.label}}</text>
        </view>
        <view class="flex-col" style="align-items:flex-end;">
          <text class="text-2xl font-mono font-bold" style="color:{{item.color}};">{{item.score}}</text>
          <text class="text-xs text-dim" style="margin-top:2rpx;">权重 {{item.weight}}%</text>
        </view>
      </view>

      <!-- Headline -->
      <text class="text-sm text-white" style="line-height:1.5; display:block; margin-bottom:16rpx;">{{item.headline}}</text>

      <!-- Sub-factors -->
      <view wx:for="{{item.factors}}" wx:for-item="f" wx:key="key" class="flex items-center gap-sm" style="margin-bottom:10rpx;">
        <text class="text-xs text-muted" style="width:180rpx;">{{f.label}}</text>
        <view class="progress-bar" style="flex:1;">
          <view class="progress-fill" style="width:{{f.score}}%; background:{{f.barColor}}; opacity:0.75;"></view>
        </view>
        <text class="text-xs text-white font-mono" style="width:120rpx; text-align:right;">{{f.valStr}}</text>
      </view>

      <!-- Annotation -->
      <view style="margin-top:16rpx; padding:12rpx 14rpx; background:rgba(255,255,255,0.03); border:1rpx solid rgba(255,255,255,0.06); border-radius:10rpx;">
        <text class="text-xs text-muted" style="line-height:1.5;">{{item.annotation}}</text>
      </view>
    </view>

    <view style="padding:20rpx 0; text-align:center;">
      <text class="text-dim text-xs">价格 · 预期 · 驱动 · 财政 · 叙事</text>
    </view>
  </block>

</view>
