<view class="container">

  <view wx:if="{{loading}}" class="text-center text-muted" style="padding:100rpx 0;">Loading...</view>
  <view wx:elif="{{error}}" class="text-center text-red" style="padding:100rpx 0;">{{error}}</view>

  <block wx:else>

    <view class="section-divider">
      <view class="line"></view>
      <text class="label">四情景剧本</text>
      <view class="line"></view>
    </view>

    <!-- Pills -->
    <view class="pill-row">
      <view
        wx:for="{{pills}}" wx:key="key"
        class="{{item.pillClass}}"
        data-key="{{item.key}}" bindtap="onPillTap">
        {{item.emoji}} {{item.label}} <text style="opacity:0.7;">{{item.probPct}}%</text>
        <text wx:if="{{item.isCurrent}}" class="text-green" style="margin-left:4rpx;">●</text>
      </view>
    </view>

    <!-- Active scenario -->
    <block wx:if="{{active}}">
      <!-- Header card -->
      <view class="card">
        <view class="flex justify-between items-center mb-sm">
          <view class="flex items-center gap-sm">
            <text class="text-xl">{{active.emoji}}</text>
            <text class="text-lg font-semibold text-white">{{active.label}}剧本</text>
            <view class="badge {{active.badgeClass}}">{{active.probPct}}%</view>
          </view>
          <text wx:if="{{active.isCurrent}}" class="text-green text-xs">● 当前</text>
        </view>
        <text class="text-sm text-muted" style="line-height:1.6; display:block;">{{active.description}}</text>

        <view style="margin-top:14rpx; padding-top:14rpx; border-top:1rpx solid rgba(255,255,255,0.06);">
          <view class="flex justify-between items-center" style="margin-bottom:8rpx;">
            <text class="text-xs text-dim">历史对照</text>
            <text class="text-xs text-white text-right" style="flex:1; margin-left:16rpx;">{{active.historical}}</text>
          </view>
          <view class="flex justify-between items-center">
            <text class="text-xs text-dim">中位数持续</text>
            <text class="text-xs text-white font-mono">{{active.duration}} 月</text>
          </view>
        </view>
      </view>

      <!-- Exit paths -->
      <view class="card">
        <text class="card-title mb-sm">退出路径</text>
        <view wx:for="{{active.exitPaths}}" wx:for-item="p" wx:key="path" class="flex items-center gap-sm" style="margin-bottom:10rpx;">
          <text class="text-xs text-muted" style="width:180rpx;">{{p.path}}</text>
          <view class="progress-bar" style="flex:1;">
            <view class="progress-fill" style="width:{{p.weightPct}}%; background:#94A3B8; opacity:0.6;"></view>
          </view>
          <text class="text-xs text-white font-mono" style="width:60rpx; text-align:right;">{{p.weightPct}}%</text>
        </view>
      </view>

      <!-- Asset performance -->
      <view class="card">
        <text class="card-title mb-sm">资产历史年化表现 (中位数区间)</text>
        <view wx:for="{{active.performance}}" wx:for-item="p" wx:key="asset" style="padding:14rpx; background:rgba(255,255,255,0.03); border-radius:10rpx; margin-bottom:10rpx;">
          <view class="flex justify-between items-center" style="margin-bottom:8rpx;">
            <view class="flex items-center gap-sm">
              <text class="text-md">{{p.emoji}}</text>
              <text class="text-sm text-white">{{p.label}}</text>
            </view>
            <view class="badge {{p.directionBadgeClass}}" style="font-size:18rpx; padding:4rpx 12rpx;">{{p.directionLabel}}</view>
          </view>
          <view class="flex items-center gap-sm">
            <text class="text-xs text-dim font-mono" style="width:80rpx; text-align:right;">{{p.loText}}</text>
            <view style="flex:1; height:10rpx; background:rgba(15,23,42,0.8); border-radius:5rpx; position:relative;">
              <view style="position:absolute; top:0; bottom:0; left:{{p.barLeft}}%; width:{{p.barWidth}}%; background:{{p.barColor}}; opacity:0.7; border-radius:5rpx;"></view>
            </view>
            <text class="text-xs text-dim font-mono" style="width:80rpx;">{{p.hiText}}</text>
          </view>
        </view>
      </view>

      <!-- Suggested weights -->
      <view class="card">
        <text class="card-title mb-sm">建议配置 (vs 中性基准)</text>
        <view wx:for="{{active.weights}}" wx:for-item="w" wx:key="asset" style="padding:14rpx; background:rgba(255,255,255,0.03); border-radius:10rpx; margin-bottom:10rpx;">
          <view class="flex justify-between items-center" style="margin-bottom:4rpx;">
            <view class="flex items-center gap-sm">
              <text class="text-md">{{w.emoji}}</text>
              <text class="text-sm text-white">{{w.label}}</text>
            </view>
            <text class="text-md {{w.deltaClass}} font-mono font-bold">{{w.deltaText}}</text>
          </view>
          <view class="flex items-center gap-sm" style="margin-bottom:4rpx;">
            <text class="text-xs text-dim font-mono">当前 {{w.currentPct}}%</text>
            <text class="text-xs text-dim">|</text>
            <text class="text-xs text-dim font-mono">基准 {{w.neutralPct}}%</text>
          </view>
          <text class="text-xs text-muted">{{w.note}}</text>
        </view>
        <view style="margin-top:12rpx; padding:12rpx; background:rgba(239,68,68,0.08); border:1rpx solid rgba(239,68,68,0.25); border-radius:10rpx;">
          <text class="text-xs text-red" style="line-height:1.5;">⚠ {{active.keyRisks}}</text>
        </view>
      </view>
    </block>

  </block>

</view>
